{
  "env": {
    "ADMIN_API_KEY": "egymac123@"
  },
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/_/backend/api/seo/sitemap.xml"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "express",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend/data/**,node_modules/@sparticuz/**"
    }
  }
}
